@model IEnumerable<BlogCoreSolution.Models.ApplicationUser>

@{
    ViewData["Title"] = "Lista de Usuarios";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-8">
            <h2 class="text-primary">Lista de Usuarios</h2>
        </div>

        <div class="col-4 text-right">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-info">
                Registrar un nuevo usuario
            </a>
        </div>
    </div>
    <br />
    <br />
    @if (Model.Count() > 0) // Existen registros de usuarios.
    {
        <table id="tblCategorias" class="table table-striped table-bordered" style="width: 100%">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(m => item.Id)</td>
                        <td>@Html.DisplayFor(m => item.Nombre)</td>
                        <td>@Html.DisplayFor(m => item.Email)</td>
                        <td>
                            @if(item.LockoutEnd == null || item.LockoutEnd < DateTime.Now)
                            { // El usuario está desbloqueado.
                                <a class="btn btn-success text-white" asp-action="Bloquear" style="width: 140px" asp-route-id="@item.Id">
                                    Bloquear
                                </a>
                            }
                            else
                            { // El usuario está bloqueado.
                                <a class="btn btn-success text-white" asp-action="Desbloquear" style="width: 140px" asp-route-id="@item.Id">
                                    Desbloquear
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>